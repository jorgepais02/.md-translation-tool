# -----------------------------------------------------------
# API Keys for the Markdown Translation Tool
# -----------------------------------------------------------

# Gemini API Key (Required for auto-generating Markdown from rough text)
# Get it for free at: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"
# DeepL API Key (Required if using DeepL provider)
# Get it from: https://www.deepl.com/pro-api
DEEPL_API_KEY="your_deepl_api_key_here"

# Azure AI Translator API Key and Region (Required if using Azure provider)
# Get it from: https://portal.azure.com/ (Cognitive Services)
AZURE_TRANSLATOR_KEY="your_azure_translator_key_here"
AZURE_TRANSLATOR_REGION="your_azure_region_here" # e.g., westeurope, eastus

# Google Docs & Drive Integration
# 1. You must obtain an OAuth2 Client ID from Google Cloud Console.
# 2. Download the credentials JSON and place it exactly at:
#    secrets/credentials.json
# 3. Upon your first execution with Google Drive enabled, 
#    a browser window will pop up asking for authorization.
#    It will generate a secrets/token.json file automatically.

# Optional: Google Drive folder ID (fallback if not set in config.json → drive.folder_id).
# Prefer setting it in config.json. Use this only if you need to keep it out of the repo.
# Get it from the Drive folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=""

